<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ReportSystem.ViewModels"
             xmlns:dg="clr-namespace:Avalonia.Controls;assembly=Avalonia.Controls.DataGrid"
             xmlns:m="using:ReportSystem.Models"
             x:Class="ReportSystem.Views.AdminUsersView"
             x:DataType="vm:AdminUsersViewModel">

    <StackPanel Spacing="15" Margin="10">
        <TextBlock Text="Список пользователей и роли" FontSize="20" FontWeight="Bold"/>
        <Separator/>

        <!-- Search -->
        <StackPanel Orientation="Horizontal" Spacing="10" Margin="0,5">
            <TextBlock Text="Поиск пользователя:" VerticalAlignment="Center"/>
            <TextBox Text="{Binding SearchText}" Watermark="ФИО или логин..." Width="200"/>
        </StackPanel>

        <!-- Grid -->
        <dg:DataGrid ItemsSource="{Binding Users}"
                  SelectedItem="{Binding SelectedUser}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  CanUserResizeColumns="True"
                  GridLinesVisibility="All"
                  BorderBrush="Gray"
                  BorderThickness="1"
                  Height="280">
            <dg:DataGrid.Columns>
                <dg:DataGridTextColumn Header="ID" Binding="{Binding Id, Mode=OneWay}" x:DataType="m:User" Width="50"/>
                <dg:DataGridTextColumn Header="ФИО" Binding="{Binding FullName, Mode=OneWay}" x:DataType="m:User" Width="*"/>
                <dg:DataGridTextColumn Header="Логин" Binding="{Binding Login, Mode=OneWay}" x:DataType="m:User" Width="150"/>
                <dg:DataGridTextColumn Header="Роль" Binding="{Binding Role.Name, Mode=OneWay}" x:DataType="m:User" Width="100"/>
            </dg:DataGrid.Columns>
        </dg:DataGrid>

        <!-- Actions -->
        <StackPanel Spacing="5" Margin="0,5" IsVisible="{Binding SelectedUser, Converter={x:Static ObjectConverters.IsNotNull}}">
            <TextBlock Text="Смена роли для выбранного пользователя:" FontWeight="Bold"/>
            <StackPanel Orientation="Horizontal" Spacing="10">
                <Button Content="Сделать Администратором" Command="{Binding ChangeRoleCommand}" CommandParameter="Admin"/>
                <Button Content="Сделать Преподавателем" Command="{Binding ChangeRoleCommand}" CommandParameter="Teacher"/>
                <Button Content="Сделать Учеником" Command="{Binding ChangeRoleCommand}" CommandParameter="Student"/>
            </StackPanel>
            <Button Content="Удалить пользователя" Command="{Binding DeleteUserCommand}" Foreground="Red" Margin="0,10,0,0"/>
        </StackPanel>

    </StackPanel>
</UserControl>
