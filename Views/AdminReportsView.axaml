<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ReportSystem.ViewModels"
             xmlns:dg="clr-namespace:Avalonia.Controls;assembly=Avalonia.Controls.DataGrid"
             xmlns:m="using:ReportSystem.Models"
             x:Class="ReportSystem.Views.AdminReportsView"
             x:DataType="vm:AdminReportsViewModel">

    <StackPanel Spacing="20" Margin="10">
        <StackPanel Spacing="5">
            <TextBlock Text="Все жалобы в системе" FontSize="24" FontWeight="SemiBold" Foreground="#1e293b"/>
            <TextBlock Text="Просмотр и управление всеми зарегистрированными жалобами" Foreground="#64748b"/>
        </StackPanel>

        <Border Background="White" BorderBrush="#e2e8f0" BorderThickness="1" CornerRadius="8" Padding="15">
            <StackPanel Orientation="Horizontal" Spacing="15" VerticalAlignment="Center">
                <TextBlock Text="Поиск:" VerticalAlignment="Center" Foreground="#475569" FontWeight="Medium"/>
                <TextBox Text="{Binding SearchText}" Watermark="Введите текст..." Width="200"/>
                
                <TextBlock Text="Статус:" VerticalAlignment="Center" Margin="15,0,0,0" Foreground="#475569" FontWeight="Medium"/>
                <ComboBox ItemsSource="{Binding StatusFilters}" SelectedItem="{Binding FilterStatus}" Width="150"/>
                
            </StackPanel>
        </Border>

        <TextBlock Text="{Binding StatusMessage}" Foreground="#ef4444" FontWeight="Medium" Margin="0,0,0,5" IsVisible="{Binding StatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>

        <Border BorderBrush="#e2e8f0" BorderThickness="1" CornerRadius="8" ClipToBounds="True">
            <dg:DataGrid ItemsSource="{Binding Reports}"
                      SelectedItem="{Binding SelectedReport}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      CanUserResizeColumns="True"
                      GridLinesVisibility="Horizontal"
                      RowBackground="White"
                      Height="350">
            <dg:DataGrid.Columns>
                <dg:DataGridTextColumn Header="ID" Binding="{Binding Id, Mode=OneWay}" x:DataType="m:Report" Width="50"/>
                <dg:DataGridTextColumn Header="Автор" Binding="{Binding Author.FullName, Mode=OneWay}" x:DataType="m:Report" Width="120"/>
                <dg:DataGridTextColumn Header="Нарушитель" Binding="{Binding Violator.FullName, Mode=OneWay}" x:DataType="m:Report" Width="120"/>
                <dg:DataGridTextColumn Header="Категория" Binding="{Binding Category.Name, Mode=OneWay}" x:DataType="m:Report" Width="100"/>
                <dg:DataGridTextColumn Header="Достов. %" Binding="{Binding ReliabilityScore, Mode=OneWay}" x:DataType="m:Report" Width="80"/>
                <dg:DataGridTemplateColumn Header="Описание" Width="*">
                    <dg:DataGridTemplateColumn.CellTemplate>
                        <DataTemplate x:DataType="m:Report">
                            <TextBlock Text="{Binding Description}" TextWrapping="Wrap" VerticalAlignment="Center" Margin="5"/>
                        </DataTemplate>
                    </dg:DataGridTemplateColumn.CellTemplate>
                </dg:DataGridTemplateColumn>
                <dg:DataGridTextColumn Header="Статус" Binding="{Binding Status.Name, Mode=OneWay}" x:DataType="m:Report" Width="100"/>
                <dg:DataGridTextColumn Header="Дата" Binding="{Binding CreatedAt, Mode=OneWay, StringFormat=dd.MM.yyyy}" x:DataType="m:Report" Width="100"/>
            </dg:DataGrid.Columns>
        </dg:DataGrid>
        </Border>

        <Border Background="White" BorderBrush="#e2e8f0" BorderThickness="1" CornerRadius="8" Padding="15">
            <StackPanel Spacing="10">
                <TextBlock Text="Управление статусом выделенной записи" FontWeight="SemiBold" Foreground="#1e293b"/>
                <StackPanel Orientation="Horizontal" Spacing="15">
                    <Button Content="В работу" Command="{Binding ChangeStatusCommand}" CommandParameter="В разработке" Background="#eab308" Foreground="White" FontWeight="Medium" Padding="15,8" CornerRadius="6"/>
                    <Button Content="Принять (Виновен)" Command="{Binding ChangeStatusCommand}" CommandParameter="Виновен (Принято)" Background="#22c55e" Foreground="White" FontWeight="Medium" Padding="15,8" CornerRadius="6"/>
                    <Button Content="Отклонить (Оправдан)" Command="{Binding ChangeStatusCommand}" CommandParameter="Оправдан (Отклонено)" Background="#ef4444" Foreground="White" FontWeight="Medium" Padding="15,8" CornerRadius="6"/>
                </StackPanel>
            </StackPanel>
        </Border>

    </StackPanel>
</UserControl>
