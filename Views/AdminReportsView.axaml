<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ReportSystem.ViewModels"
             xmlns:dg="clr-namespace:Avalonia.Controls;assembly=Avalonia.Controls.DataGrid"
             xmlns:m="using:ReportSystem.Models"
             x:Class="ReportSystem.Views.AdminReportsView"
             x:DataType="vm:AdminReportsViewModel">

    <StackPanel Spacing="15" Margin="10">
        <TextBlock Text="Все жалобы в системе" FontSize="20" FontWeight="Bold"/>
        <Separator/>

        <!-- Filters -->
        <StackPanel Orientation="Horizontal" Spacing="10" Margin="0,5">
            <TextBlock Text="Поиск:" VerticalAlignment="Center"/>
            <TextBox Text="{Binding SearchText}" Watermark="Введите текст..." Width="180"/>
            
            <TextBlock Text="Фильтр статуса:" VerticalAlignment="Center" Margin="10,0,0,0"/>
            <ComboBox ItemsSource="{Binding StatusFilters}" SelectedItem="{Binding FilterStatus}" Width="130"/>
        </StackPanel>

        <!-- Grid -->
        <dg:DataGrid ItemsSource="{Binding Reports}"
                  SelectedItem="{Binding SelectedReport}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  GridLinesVisibility="All"
                  BorderBrush="Gray"
                  BorderThickness="1"
                  Height="300">
            <dg:DataGrid.Columns>
                <dg:DataGridTextColumn Header="ID" Binding="{Binding Id}" x:DataType="m:Report" Width="50"/>
                <dg:DataGridTextColumn Header="Автор" Binding="{Binding Author.FullName}" x:DataType="m:Report" Width="140"/>
                <dg:DataGridTextColumn Header="Категория" Binding="{Binding Category.Name}" x:DataType="m:Report" Width="120"/>
                <dg:DataGridTextColumn Header="Описание" Binding="{Binding Description}" x:DataType="m:Report" Width="*"/>
                <dg:DataGridTextColumn Header="Статус" Binding="{Binding Status.Name}" x:DataType="m:Report" Width="100"/>
                <dg:DataGridTextColumn Header="Дата" Binding="{Binding CreatedAt, StringFormat=dd.MM.yyyy}" x:DataType="m:Report" Width="100"/>
            </dg:DataGrid.Columns>
        </dg:DataGrid>

        <!-- Control Actions -->
        <StackPanel Spacing="5" Margin="0,5">
            <TextBlock Text="Управление статусом выделенной записи:" FontWeight="Bold"/>
            <StackPanel Orientation="Horizontal" Spacing="10">
                <Button Content="В работу" Command="{Binding ChangeStatusCommand}" CommandParameter="InProgress" Background="#E1BEE7"/>
                <Button Content="Решено" Command="{Binding ChangeStatusCommand}" CommandParameter="Resolved" Background="#C8E6C9"/>
                <Button Content="Отклонить" Command="{Binding ChangeStatusCommand}" CommandParameter="Rejected" Background="#FFCDD2"/>
            </StackPanel>
        </StackPanel>

    </StackPanel>
</UserControl>
