<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:ReportSystem.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="520"
        x:Class="ReportSystem.Views.LoginWindow"
        x:DataType="vm:LoginViewModel"
        Title="Авторизация — Система мониторинга"
        Width="800" Height="520"
        WindowStartupLocation="CenterScreen"
        CanResize="False"
        Background="#1A1F2E">

    <Window.Styles>
        <Style Selector="TextBox">
            <Setter Property="Background" Value="#F8F9FA"/>
            <Setter Property="Foreground" Value="#1A1F2E"/>
            <Setter Property="BorderBrush" Value="#DEE2E6"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Height" Value="44"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>
        <Style Selector="TextBox /template/ Border#PART_BorderElement">
            <Setter Property="Background" Value="#F8F9FA"/>
        </Style>
        <Style Selector="TextBox:focus">
            <Setter Property="BorderBrush" Value="#1976D2"/>
            <Setter Property="Background" Value="White"/>
        </Style>
        <Style Selector="TextBox:focus /template/ Border#PART_BorderElement">
            <Setter Property="Background" Value="White"/>
        </Style>
        <Style Selector="Button.PrimaryBtn">
            <Setter Property="Background" Value="#1976D2"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Height" Value="46"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
        </Style>
        <Style Selector="Button.PrimaryBtn:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#1565C0"/>
        </Style>
        <Style Selector="Button.LinkBtn">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#1976D2"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="Padding" Value="0"/>
        </Style>
    </Window.Styles>

    <Grid ColumnDefinitions="2.2*, 2.8*">

        <!-- Левая панель — брендинг -->
        <Border Grid.Column="0">
            <Border.Background>
                <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
                    <GradientStop Color="#0D47A1" Offset="0"/>
                    <GradientStop Color="#1565C0" Offset="0.5"/>
                    <GradientStop Color="#1976D2" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="40" Spacing="20">
                <TextBlock Text="🛡️" FontSize="56" HorizontalAlignment="Center"/>
                <TextBlock Text="Система мониторинга&#x0a;нарушений дисциплины"
                           FontSize="22" FontWeight="Bold"
                           Foreground="White"
                           TextAlignment="Center"
                           TextWrapping="Wrap"/>
                <Rectangle Height="2" Width="60" Fill="#FFFFFF40" HorizontalAlignment="Center"/>
                <TextBlock Text="Защити свою школу.&#x0a;Каждый голос важен."
                           FontSize="13"
                           Foreground="#FFFFFFB0"
                           TextAlignment="Center"
                           TextWrapping="Wrap"/>
                <StackPanel Spacing="10" Margin="0,10,0,0">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="10">
                        <TextBlock Text="✓" Foreground="#80DEEA" FontWeight="Bold"/>
                        <TextBlock Text="Анонимные обращения" Foreground="#FFFFFFB0" FontSize="12"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="10">
                        <TextBlock Text="✓" Foreground="#80DEEA" FontWeight="Bold"/>
                        <TextBlock Text="Защита персональных данных" Foreground="#FFFFFFB0" FontSize="12"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="10">
                        <TextBlock Text="✓" Foreground="#80DEEA" FontWeight="Bold"/>
                        <TextBlock Text="Быстрая обратная связь" Foreground="#FFFFFFB0" FontSize="12"/>
                    </StackPanel>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Правая панель — форма входа -->
        <Border Grid.Column="1" Background="White">
            <StackPanel VerticalAlignment="Center" Margin="50,0" Spacing="0">

                <TextBlock Text="Добро пожаловать!"
                           FontSize="26" FontWeight="Bold"
                           Foreground="#1A1F2E"
                           Margin="0,0,0,4"/>
                <TextBlock Text="Войдите в свой аккаунт"
                           FontSize="14" Foreground="#6C757D"
                           Margin="0,0,0,30"/>

                <!-- Логин -->
                <TextBlock Text="Логин" FontWeight="SemiBold" FontSize="13"
                           Foreground="#495057" Margin="0,0,0,6"/>
                <TextBox Text="{Binding Login}"
                         Watermark="Введите ваш логин"
                         Margin="0,0,0,16"/>

                <!-- Пароль -->
                <TextBlock Text="Пароль" FontWeight="SemiBold" FontSize="13"
                           Foreground="#495057" Margin="0,0,0,6"/>
                <TextBox Text="{Binding Password}"
                         PasswordChar="•"
                         RevealPassword="{Binding ShowPassword}"
                         Watermark="Введите пароль"
                         Margin="0,0,0,12">
                    <TextBox.InnerRightContent>
                        <ToggleButton IsChecked="{Binding ShowPassword}" 
                                      Padding="10,0"
                                      Background="Transparent"
                                      BorderThickness="0"
                                      Cursor="Hand">
                            <PathIcon Data="M12 4.5C7 4.5 2.73 7.61 1 12c1.73 4.39 6 7.5 11 7.5s9.27-3.11 11-7.5c-1.73-4.39-6-7.5-11-7.5zM12 17c-2.76 0-5-2.24-5-5s2.24-5 5-5 5 2.24 5 5-2.24 5-5 5zm0-8c-1.66 0-3 1.34-3 3s1.34 3 3 3 3-1.34 3-3-1.34-3-3-3z"
                                      Width="16" Height="16"
                                      Foreground="#6C757D"/>
                        </ToggleButton>
                    </TextBox.InnerRightContent>
                </TextBox>

                <!-- Запомнить -->
                <CheckBox IsChecked="{Binding RememberMe}"
                          Content="Запомнить меня"
                          FontSize="13" Foreground="#6C757D"
                          Margin="0,0,0,20"/>

                <!-- Сообщение об ошибке -->
                <Border Background="#FFF3F3" CornerRadius="8" Padding="12,8"
                        Margin="0,0,0,16"
                        IsVisible="{Binding HasMessage}">
                    <TextBlock Text="{Binding ErrorMessage}"
                               Foreground="#D32F2F"
                               FontSize="13"
                               TextWrapping="Wrap"/>
                </Border>

                <!-- Кнопка входа -->
                <Button Command="{Binding LoginCommand}"
                        Content="ВОЙТИ"
                        Classes="PrimaryBtn"
                        Margin="0,0,0,16"/>

                <!-- Разделитель -->
                <Grid ColumnDefinitions="*,Auto,*" Margin="0,0,0,16">
                    <Rectangle Grid.Column="0" Height="1" Fill="#DEE2E6" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="1" Text="или" Foreground="#ADB5BD"
                               FontSize="12" Margin="12,0"/>
                    <Rectangle Grid.Column="2" Height="1" Fill="#DEE2E6" VerticalAlignment="Center"/>
                </Grid>

                <!-- Кнопка регистрации -->
                <Button Name="OpenRegisterBtn"
                        Content="Нет аккаунта? Зарегистрироваться"
                        Classes="LinkBtn"/>

            </StackPanel>
        </Border>
    </Grid>
</Window>