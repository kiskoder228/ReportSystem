<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:ReportSystem.ViewModels"
        x:Class="ReportSystem.Views.LoginWindow"
        x:DataType="vm:LoginViewModel"
        Title="Авторизация — Система мониторинга"
        Width="460" Height="480"
        WindowStartupLocation="CenterScreen"
        CanResize="False"
        Background="White">

    <Border Background="White" Margin="40" VerticalAlignment="Center">
        <StackPanel Spacing="10">
            <TextBlock Text="Вход в систему" FontSize="22" FontWeight="Bold"/>
            <TextBlock Text="Введите данные вашего аккаунта"/>

            <TextBlock Text="Логин" />
            <TextBox Text="{Binding Login}"/>

            <TextBlock Text="Пароль" />
            <TextBox Text="{Binding Password}" PasswordChar="*"/>

            <CheckBox IsChecked="{Binding RememberMe}">
                <TextBlock Text="Запомнить меня"/>
            </CheckBox>

            <Border Background="White" Padding="20" IsVisible="{Binding HasMessage}">
                <TextBlock Text="{Binding ErrorMessage}" Foreground="Red"/>
            </Border>

            <Button Command="{Binding LoginCommand}" Content="Войти" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <TextBlock Text="Нет аккаунта?" />
                <Button Name="OpenRegisterBtn" Content="Зарегистрироваться"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
