<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:ReportSystem.ViewModels"
        x:Class="ReportSystem.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="Система мониторинга нарушений"
        Width="1000" Height="650"
        WindowStartupLocation="CenterScreen"
        Background="#F0F2F5">

    <Window.Styles>
        <Style Selector="Button.NavBtn">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>
        <Style Selector="Button.LogoutBtn">
            <Setter Property="Background" Value="Red"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="Margin" Value="10"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
    </Window.Styles>

    <Grid ColumnDefinitions="240,*">
        
        <Border Grid.Column="0" Background="LightGray" Padding="10">
            <Grid RowDefinitions="Auto,*,Auto">
                
                <StackPanel Grid.Row="0" Margin="15,20,15,20">
                    <TextBlock Text="Мониторинг" FontSize="20" FontWeight="Bold" Foreground="Black" Margin="5,0,0,0"/>
                    <Border Width="48" Height="48" Background="Gray" CornerRadius="24">
                        <TextBlock Text="U" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="{Binding UserName}" FontWeight="Bold"/>
                        <TextBlock Text="{Binding UserRole}"/>
                    </StackPanel>
                </StackPanel>

                <ScrollViewer Grid.Row="1">
                    <StackPanel>
                        <TextBlock Text="МЕНЮ" FontSize="11" FontWeight="Bold" Foreground="#64748B" Margin="15,10,0,10"/>

                        <StackPanel IsVisible="{Binding IsStudent}">
                            <Button Name="NavDashboard" Content="Главная" Classes="NavBtn"/>
                            <Button Name="NavCreate" Content="Создать жалобу" Classes="NavBtn"/>
                            <Button Name="NavMy" Content="Мои обращения" Classes="NavBtn"/>
                        </StackPanel>

                        <StackPanel IsVisible="{Binding IsTeacher}">
                            <Button Name="NavTeacherDash" Content="Главная" Classes="NavBtn"/>
                            <Button Name="NavTeacherReports" Content="Список нарушений" Classes="NavBtn"/>
                        </StackPanel>

                        <StackPanel IsVisible="{Binding IsAdmin}">
                            <Button Name="NavAdminDash" Content="Главная" Classes="NavBtn"/>
                            <Button Name="NavAdminReports" Content="Все обращения" Classes="NavBtn"/>
                            <Button Name="NavAdminUsers" Content="Пользователи" Classes="NavBtn"/>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>

                <StackPanel Grid.Row="2" Margin="0,0,0,10">
                    <Button Name="LogoutBtn" Content="Выйти" Classes="LogoutBtn"/>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Column="1" Padding="24">
            <ContentControl Content="{Binding CurrentPage}"/>
        </Border>

    </Grid>
</Window>
