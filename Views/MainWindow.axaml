<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:ReportSystem.ViewModels"
        x:Class="ReportSystem.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="Система мониторинга нарушений (Курсовая работа)"
        Width="950" Height="600"
        WindowStartupLocation="CenterScreen">

    <Grid ColumnDefinitions="200,*">
        
        <!-- Left Panel: Menu -->
        <Border Grid.Column="0" Padding="10">
            <Grid RowDefinitions="Auto,*,Auto">
                
                <!-- Profile Info -->
                <StackPanel Grid.Row="0" Margin="5,10" Spacing="5">
                    <TextBlock Text="Навигация" FontSize="18" FontWeight="Bold" Margin="0,0,0,10"/>
                    <TextBlock Text="Пользователь:" FontSize="11" Foreground="Gray"/>
                    <TextBlock Text="{Binding UserName}" FontWeight="Bold" TextWrapping="Wrap"/>
                    <TextBlock Text="{Binding UserRole}" FontSize="12"/>
                    <Separator Margin="0,10"/>
                </StackPanel>

                <!-- Navigation Links -->
                <ScrollViewer Grid.Row="1">
                    <StackPanel Spacing="6">
                        <StackPanel IsVisible="{Binding IsStudent}" Spacing="6">
                            <Button Content="Главная страница" Command="{Binding NavigateCommand}" CommandParameter="Dashboard" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"/>
                            <Button Content="Создать жалобу" Command="{Binding NavigateCommand}" CommandParameter="CreateReport" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"/>
                            <Button Content="Мои обращения" Command="{Binding NavigateCommand}" CommandParameter="MyReports" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"/>
                        </StackPanel>

                        <StackPanel IsVisible="{Binding IsTeacher}" Spacing="6">
                            <Button Content="Главная страница" Command="{Binding NavigateCommand}" CommandParameter="Dashboard" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"/>
                            <Button Content="Список нарушений" Command="{Binding NavigateCommand}" CommandParameter="AllReports" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"/>
                        </StackPanel>

                        <StackPanel IsVisible="{Binding IsAdmin}" Spacing="6">
                            <Button Content="Главная страница" Command="{Binding NavigateCommand}" CommandParameter="Dashboard" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"/>
                            <Button Content="Все обращения" Command="{Binding NavigateCommand}" CommandParameter="AllReports" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"/>
                            <Button Content="Пользователи" Command="{Binding NavigateCommand}" CommandParameter="Users" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"/>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>

                <!-- Logout Button -->
                <StackPanel Grid.Row="2" Margin="0,10,0,0">
                    <Button Name="LogoutBtn" Content="Выйти" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Click="OnLogoutClick"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Right Panel: Main Content Area -->
        <Border Grid.Column="1" Padding="15">
            <ContentControl Content="{Binding CurrentPage}"/>
        </Border>

    </Grid>
</Window>
