<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ReportSystem.ViewModels"
             x:Class="ReportSystem.Views.CreateReportPage"
             x:DataType="vm:CreateReportViewModel">

    <ScrollViewer>
        <StackPanel Spacing="20" MaxWidth="680">

            <TextBlock Text="Создать новую жалобу" FontSize="22" FontWeight="Bold"/>

            <Border Background="LightGray" BorderBrush="Black" BorderThickness="1" Padding="20">
                <StackPanel Spacing="20">
                    
                    <StackPanel Spacing="6">
                        <TextBlock Text="Категория нарушения *"/>
                        <ComboBox ItemsSource="{Binding Categories}"
                                  SelectedItem="{Binding SelectedCategory}"
                                  DisplayMemberBinding="{Binding Name}"
                                  HorizontalAlignment="Stretch"/>
                    </StackPanel>

                    <StackPanel Spacing="6">
                        <TextBlock Text="Описание ситуации *"/>
                        <TextBox Text="{Binding Description}"
                                 Watermark="Подробно опишите произошедшее"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 Height="140"/>
                    </StackPanel>

                    <CheckBox IsChecked="{Binding IsAnonymous}">
                        <TextBlock Text="Отправить анонимно"/>
                    </CheckBox>

                    <Border Background="White" Padding="15" IsVisible="{Binding HasMessage}">
                        <TextBlock Text="{Binding StatusMessage}" Foreground="Black"/>
                    </Border>

                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                        <Button Grid.Column="0"
                                Command="{Binding SubmitCommand}"
                                Content="Отправить жалобу"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Center"/>
                        <Button Grid.Column="1"
                                Command="{Binding ClearCommand}"
                                Content="Очистить"
                                Padding="20,0"/>
                    </Grid>

                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
