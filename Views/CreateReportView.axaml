<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ReportSystem.ViewModels"
             x:Class="ReportSystem.Views.CreateReportView"
             x:DataType="vm:CreateReportViewModel">

    <StackPanel Spacing="15" Margin="10" MaxWidth="500" HorizontalAlignment="Left">
        <TextBlock Text="Форма создания жалобы" FontSize="20" FontWeight="Bold"/>
        <Separator/>

        <StackPanel Spacing="5">
            <TextBlock Text="Выберите категорию нарушения:"/>
            <ComboBox ItemsSource="{Binding Categories}"
                      SelectedItem="{Binding SelectedCategory}"
                      DisplayMemberBinding="{Binding Name}"
                      HorizontalAlignment="Stretch"/>
        </StackPanel>

        <StackPanel Spacing="5">
            <TextBlock Text="Подробное описание произошедшего:"/>
            <TextBox Text="{Binding Description}"
                     Height="120"
                     AcceptsReturn="True"
                     TextWrapping="Wrap"/>
        </StackPanel>

        <CheckBox IsChecked="{Binding IsAnonymous}" Content="Отправить анонимно"/>

        <Border BorderBrush="Gray" BorderThickness="1" Padding="10" Background="#F5F5F5" IsVisible="{Binding HasMessage}">
            <TextBlock Text="{Binding StatusMessage}" Foreground="Blue" TextWrapping="Wrap"/>
        </Border>

        <StackPanel Orientation="Horizontal" Spacing="10" Margin="0,10,0,0">
            <Button Content="Очистить форму" Command="{Binding ClearCommand}"/>
            <Button Content="Отправить" Command="{Binding SubmitCommand}" FontWeight="Bold"/>
        </StackPanel>
    </StackPanel>
</UserControl>
