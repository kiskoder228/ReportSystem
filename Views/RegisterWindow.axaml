<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:ReportSystem.ViewModels"
        x:Class="ReportSystem.Views.RegisterWindow"
        x:DataType="vm:RegisterViewModel"
        Title="Регистрация — Система мониторинга"
        Width="800" Height="560"
        WindowStartupLocation="CenterScreen"
        CanResize="False"
        Background="#1A1F2E">

    <Window.Styles>
        <Style Selector="TextBox">
            <Setter Property="Background" Value="#F8F9FA"/>
            <Setter Property="Foreground" Value="#1A1F2E"/>
            <Setter Property="BorderBrush" Value="#DEE2E6"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Height" Value="44"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>
        <Style Selector="TextBox /template/ Border#PART_BorderElement">
            <Setter Property="Background" Value="#F8F9FA"/>
        </Style>
        <Style Selector="TextBox:focus">
            <Setter Property="BorderBrush" Value="#1976D2"/>
            <Setter Property="Background" Value="White"/>
        </Style>
        <Style Selector="TextBox:focus /template/ Border#PART_BorderElement">
            <Setter Property="Background" Value="White"/>
        </Style>
        <Style Selector="ComboBox">
            <Setter Property="Background" Value="#F8F9FA"/>
            <Setter Property="BorderBrush" Value="#DEE2E6"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Height" Value="44"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
        </Style>
        <Style Selector="Button.PrimaryBtn">
            <Setter Property="Background" Value="#1976D2"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Height" Value="46"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
        </Style>
        <Style Selector="Button.PrimaryBtn:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#1565C0"/>
        </Style>
        <Style Selector="Button.LinkBtn">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#1976D2"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="Padding" Value="0"/>
        </Style>
    </Window.Styles>

    <Grid ColumnDefinitions="2.2*, 2.8*">

        <!-- Левая панель — брендинг -->
        <Border Grid.Column="0">
            <Border.Background>
                <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
                    <GradientStop Color="#0D47A1" Offset="0"/>
                    <GradientStop Color="#1565C0" Offset="0.5"/>
                    <GradientStop Color="#1976D2" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="40" Spacing="20">
                <TextBlock Text="📋" FontSize="56" HorizontalAlignment="Center"/>
                <TextBlock Text="Создайте аккаунт"
                           FontSize="22" FontWeight="Bold"
                           Foreground="White"
                           TextAlignment="Center"/>
                <Rectangle Height="2" Width="60" Fill="#FFFFFF40" HorizontalAlignment="Center"/>
                <TextBlock Text="Присоединяйтесь к системе&#x0a;и помогите сделать&#x0a;учёбу лучше"
                           FontSize="13"
                           Foreground="#FFFFFFB0"
                           TextAlignment="Center"
                           TextWrapping="Wrap"/>

            </StackPanel>
        </Border>

        <!-- Правая панель — форма -->
        <Border Grid.Column="1" Background="White">
            <StackPanel VerticalAlignment="Center" Margin="50,0" Spacing="0">

                <TextBlock Text="Регистрация"
                           FontSize="26" FontWeight="Bold"
                           Foreground="#1A1F2E"
                           Margin="0,0,0,4"/>
                <TextBlock Text="Заполните данные для создания аккаунта"
                           FontSize="13" Foreground="#6C757D"
                           Margin="0,0,0,24"/>

                <!-- ФИО -->
                <TextBlock Text="ФИО" FontWeight="SemiBold" FontSize="13"
                           Foreground="#495057" Margin="0,0,0,6"/>
                <TextBox Text="{Binding FullName}"
                         Watermark="Иванов Иван Иванович"
                         Margin="0,0,0,14"/>

                <!-- Логин -->
                <TextBlock Text="Логин" FontWeight="SemiBold" FontSize="13"
                           Foreground="#495057" Margin="0,0,0,6"/>
                <TextBox Text="{Binding Login}"
                         Watermark="Придумайте логин"
                         Margin="0,0,0,14"/>

                <!-- Пароль -->
                <TextBlock Text="Пароль" FontWeight="SemiBold" FontSize="13"
                           Foreground="#495057" Margin="0,0,0,6"/>
                <TextBox Text="{Binding Password}"
                         PasswordChar="•"
                         RevealPassword="{Binding ShowPassword}"
                         Watermark="Придумайте пароль"
                         Margin="0,0,0,14">
                    <TextBox.InnerRightContent>
                        <ToggleButton IsChecked="{Binding ShowPassword}" 
                                      Padding="10,0"
                                      Background="Transparent"
                                      BorderThickness="0"
                                      Cursor="Hand">
                            <PathIcon Data="M12 4.5C7 4.5 2.73 7.61 1 12c1.73 4.39 6 7.5 11 7.5s9.27-3.11 11-7.5c-1.73-4.39-6-7.5-11-7.5zM12 17c-2.76 0-5-2.24-5-5s2.24-5 5-5 5 2.24 5 5-2.24 5-5 5zm0-8c-1.66 0-3 1.34-3 3s1.34 3 3 3 3-1.34 3-3-1.34-3-3-3z"
                                      Width="16" Height="16"
                                      Foreground="#6C757D"/>
                        </ToggleButton>
                    </TextBox.InnerRightContent>
                </TextBox>

                <!-- Статус-сообщение -->
                <Border Background="#FFF3F3" CornerRadius="8" Padding="12,8"
                        Margin="0,0,0,14"
                        IsVisible="{Binding HasMessage}">
                    <TextBlock Text="{Binding StatusMessage}"
                               Foreground="{Binding MessageColor}"
                               FontSize="13" TextWrapping="Wrap"/>
                </Border>

                <!-- Кнопка -->
                <Button Command="{Binding RegisterCommand}"
                        Content="ЗАРЕГИСТРИРОВАТЬСЯ"
                        Classes="PrimaryBtn"
                        Margin="0,0,0,14"/>

                <!-- Разделитель -->
                <Grid ColumnDefinitions="*,Auto,*" Margin="0,0,0,14">
                    <Rectangle Grid.Column="0" Height="1" Fill="#DEE2E6" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="1" Text="или" Foreground="#ADB5BD"
                               FontSize="12" Margin="12,0"/>
                    <Rectangle Grid.Column="2" Height="1" Fill="#DEE2E6" VerticalAlignment="Center"/>
                </Grid>

                <Button Name="BackToLoginBtn"
                        Content="Уже есть аккаунт? Войти"
                        Classes="LinkBtn"/>

            </StackPanel>
        </Border>
    </Grid>
</Window>