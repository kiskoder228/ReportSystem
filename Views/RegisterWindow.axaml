<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:ReportSystem.ViewModels"
        x:Class="ReportSystem.Views.RegisterWindow"
        x:DataType="vm:RegisterViewModel"
        Title="Регистрация — Система мониторинга"
        Width="500" Height="680"
        WindowStartupLocation="CenterScreen"
        CanResize="False"
        Background="#f8fafc">

    <Border Background="White" BorderBrush="#e2e8f0" BorderThickness="1" CornerRadius="12" Margin="30" Padding="40" VerticalAlignment="Center">
        <StackPanel Spacing="20">
            <StackPanel Spacing="5">
                <TextBlock Text="Регистрация" FontSize="26" FontWeight="SemiBold" Foreground="#1e293b" HorizontalAlignment="Center"/>
                <TextBlock Text="Создайте новый аккаунт для входа" FontSize="14" Foreground="#64748b" HorizontalAlignment="Center"/>
            </StackPanel>

            <StackPanel Spacing="5">
                <TextBlock Text="ФИО" Foreground="#475569" FontWeight="Medium"/>
                <TextBox Text="{Binding FullName}" FontSize="15" Padding="10"/>
            </StackPanel>

            <StackPanel Spacing="5">
                <TextBlock Text="Логин" Foreground="#475569" FontWeight="Medium"/>
                <TextBox Text="{Binding Login}" FontSize="15" Padding="10"/>
            </StackPanel>

            <StackPanel Spacing="5">
                <TextBlock Text="Пароль" Foreground="#475569" FontWeight="Medium"/>
                <TextBox Text="{Binding Password}" PasswordChar="•" FontSize="15" Padding="10"/>
            </StackPanel>

            <StackPanel Spacing="5">
                <TextBlock Text="Место прописки (для доски почета)" Foreground="#475569" FontWeight="Medium"/>
                <TextBox Text="{Binding Address}" FontSize="15" Padding="10"/>
            </StackPanel>

            <Border Background="#fee2e2" BorderBrush="#fca5a5" BorderThickness="1" CornerRadius="6" Padding="15" IsVisible="{Binding HasMessage}">
                <TextBlock Text="{Binding StatusMessage}" Foreground="#ef4444" TextWrapping="Wrap" HorizontalAlignment="Center"/>
            </Border>

            <Button Command="{Binding RegisterCommand}" Content="Зарегистрироваться" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Background="#3b82f6" Foreground="White" FontWeight="SemiBold" FontSize="16" Padding="12" CornerRadius="6" Margin="0,10,0,0"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,15,0,0">
                <TextBlock Text="Уже есть аккаунт?" VerticalAlignment="Center" Margin="0,0,8,0" Foreground="#64748b"/>
                <Button Content="Войти" Click="OnBackClick" Background="Transparent" Foreground="#3b82f6" FontWeight="Medium"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
