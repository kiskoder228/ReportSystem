<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:ReportSystem.ViewModels"
        x:Class="ReportSystem.Views.RegisterWindow"
        x:DataType="vm:RegisterViewModel"
        Title="Регистрация — Система мониторинга"
        Width="460" Height="520"
        WindowStartupLocation="CenterScreen"
        CanResize="False"
        Background="White">

    <Border Padding="36" VerticalAlignment="Center">
        <StackPanel Spacing="10">
            <TextBlock Text="Регистрация" FontSize="22" FontWeight="Bold"/>
            <TextBlock Text="Заполните данные для создания аккаунта"/>

            <TextBlock Text="ФИО"/>
            <TextBox Text="{Binding FullName}"/>

            <TextBlock Text="Логин"/>
            <TextBox Text="{Binding Login}"/>

            <TextBlock Text="Пароль"/>
            <TextBox Text="{Binding Password}" PasswordChar="*"/>

            <Border Padding="20" IsVisible="{Binding HasMessage}">
                <TextBlock Text="{Binding StatusMessage}" Foreground="Red"/>
            </Border>

            <Button Command="{Binding RegisterCommand}" Content="Зарегистрироваться" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <TextBlock Text="Уже есть аккаунт?"/>
                <Button Content="Войти" Click="OnBackClick"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
