<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ReportSystem.ViewModels"
             xmlns:dg="clr-namespace:Avalonia.Controls;assembly=Avalonia.Controls.DataGrid"
             xmlns:m="using:ReportSystem.Models"
             x:Class="ReportSystem.Views.AdminUsersPage"
             x:DataType="vm:AdminUsersViewModel">

    <UserControl.Styles>
    </UserControl.Styles>

    <StackPanel Spacing="20">
        <TextBlock Text="Управление пользователями"
                   FontSize="22" FontWeight="Bold"/>

        <TextBox Text="{Binding SearchText}"
                 Watermark="Поиск по ФИО или логину..." Width="300" HorizontalAlignment="Left"/>

        <Border BorderBrush="Black" BorderThickness="1">
            <dg:DataGrid ItemsSource="{Binding Users}"
                         SelectedItem="{Binding SelectedUser}"
                         x:CompileBindings="False"
                         AutoGenerateColumns="False"
                         IsReadOnly="True"
                         GridLinesVisibility="Horizontal"
                         HeadersVisibility="Column"
                         RowBackground="White"
                         FontSize="13"
                         MinHeight="300">
                <dg:DataGrid.Columns>
                    <dg:DataGridTextColumn Header="ID" Binding="{Binding Id, Mode=OneWay}" x:DataType="m:User" Width="60"/>
                    <dg:DataGridTextColumn Header="ФИО" Binding="{Binding FullName, Mode=OneWay}" x:DataType="m:User" Width="*"/>
                    <dg:DataGridTextColumn Header="Логин" Binding="{Binding Login, Mode=OneWay}" x:DataType="m:User" Width="150"/>
                    <dg:DataGridTextColumn Header="Роль" Binding="{Binding Role.Name, Mode=OneWay}" x:DataType="m:User" Width="120"/>
                </dg:DataGrid.Columns>
            </dg:DataGrid>
        </Border>

        <StackPanel Spacing="12"
                    IsVisible="{Binding SelectedUser, Converter={x:Static ObjectConverters.IsNotNull}}">
            <TextBlock Text="Изменить роль выбранного пользователя:"/>
            <StackPanel Orientation="Horizontal" Spacing="10">
                <Button Command="{Binding ChangeRoleCommand}"
                        CommandParameter="Admin"
                        Content="Сделать Админом"/>
                <Button Command="{Binding ChangeRoleCommand}"
                        CommandParameter="Teacher"
                        Content="Сделать Преподавателем"/>
                <Button Command="{Binding ChangeRoleCommand}"
                        CommandParameter="Student"
                        Content="Сделать Учеником"/>
            </StackPanel>
        </StackPanel>
        
        <Border BorderBrush="Gray" BorderThickness="1" Padding="16"
                IsVisible="{Binding SelectedUser, Converter={x:Static ObjectConverters.IsNull}}">
            <TextBlock Text="Выберите пользователя из списка выше, чтобы изменить его роль."
                       FontSize="13" HorizontalAlignment="Center"/>
        </Border>

    </StackPanel>
</UserControl>

