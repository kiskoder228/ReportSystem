<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ReportSystem.ViewModels"
             xmlns:dg="clr-namespace:Avalonia.Controls;assembly=Avalonia.Controls.DataGrid"
             xmlns:m="using:ReportSystem.Models"
             x:Class="ReportSystem.Views.AdminReportsPage"
             x:DataType="vm:AdminReportsViewModel">

    <UserControl.Styles>
    </UserControl.Styles>

    <StackPanel Spacing="20">

        <TextBlock Text="Панель администратора"
                   FontSize="22" FontWeight="Bold"/>

        <StackPanel Orientation="Horizontal" Spacing="10">
            <TextBox Text="{Binding SearchText}"
                     Watermark="Поиск по описанию..." Width="200"/>
            <ComboBox ItemsSource="{Binding StatusFilters}"
                      SelectedItem="{Binding FilterStatus}"/>
        </StackPanel>

        
        <Border BorderBrush="Black" BorderThickness="1">
            <dg:DataGrid ItemsSource="{Binding Reports}"
                      SelectedItem="{Binding SelectedReport}"
                      x:CompileBindings="False"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      GridLinesVisibility="Horizontal"
                      HeadersVisibility="Column"
                      RowBackground="White"
                      FontSize="13"
                      MinHeight="300">
                <dg:DataGrid.Columns>
                    <dg:DataGridTextColumn Header="№" Binding="{Binding Id, Mode=OneWay}" x:DataType="m:Report" Width="60"/>
                    <dg:DataGridTextColumn Header="Автор" Binding="{Binding Author.FullName, Mode=OneWay}" x:DataType="m:Report" Width="160"/>
                    <dg:DataGridTextColumn Header="Категория" Binding="{Binding Category.Name, Mode=OneWay}" x:DataType="m:Report" Width="130"/>
                    <dg:DataGridTextColumn Header="Описание" Binding="{Binding Description, Mode=OneWay}" x:DataType="m:Report" Width="*"/>
                    <dg:DataGridTextColumn Header="Статус" Binding="{Binding Status.Name, Mode=OneWay}" x:DataType="m:Report" Width="110"/>
                    <dg:DataGridTextColumn Header="Дата" Binding="{Binding CreatedAt, StringFormat=dd.MM.yyyy, Mode=OneWay}" x:DataType="m:Report" Width="100"/>
                </dg:DataGrid.Columns>
            </dg:DataGrid>
        </Border>

        
        <StackPanel Spacing="12">
            <TextBlock Text="Изменить статус выбранного обращения:"/>
            <StackPanel Orientation="Horizontal" Spacing="10">
                <Button Command="{Binding ChangeStatusCommand}"
                        CommandParameter="InProgress"
                        Content="В работе"/>
                <Button Command="{Binding ChangeStatusCommand}"
                        CommandParameter="Resolved"
                        Content="Решено"/>
                <Button Command="{Binding ChangeStatusCommand}"
                        CommandParameter="Rejected"
                        Content="Отклонить"/>
            </StackPanel>
        </StackPanel>

    </StackPanel>
</UserControl>

