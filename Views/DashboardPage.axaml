<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ReportSystem.ViewModels"
             x:Class="ReportSystem.Views.DashboardPage"
             x:DataType="vm:DashboardPageViewModel">

    <ScrollViewer>
        <StackPanel Spacing="24" Margin="0,8,0,0">

            <!-- Приветствие -->
            <StackPanel Spacing="4">
                <TextBlock FontSize="24" FontWeight="Bold" Foreground="#1A1F2E">
                    <Run Text="Привет, "/>
                    <Run Text="{Binding GreetingName}" Foreground="#1976D2"/>
                    <Run Text="! 👋"/>
                </TextBlock>
                <TextBlock Text="Вот что происходит в системе прямо сейчас"
                           FontSize="14" Foreground="#6C757D"/>
            </StackPanel>

            <!-- Карточки статистики -->
            <WrapPanel Orientation="Horizontal">

                <!-- Всего -->
                <Border Width="200" Height="110" Background="White" CornerRadius="12"
                        Margin="0,0,16,16" BoxShadow="0 2 12 0 #15000000">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="6">
                        <TextBlock Text="📋" FontSize="28" HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding TotalReports}" FontSize="32" FontWeight="Bold"
                                   Foreground="#1976D2" HorizontalAlignment="Center"/>
                        <TextBlock Text="Всего заявок" Foreground="#6C757D" FontSize="12"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- Новые -->
                <Border Width="200" Height="110" Background="White" CornerRadius="12"
                        Margin="0,0,16,16" BoxShadow="0 2 12 0 #15000000">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="6">
                        <TextBlock Text="🆕" FontSize="28" HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding NewReports}" FontSize="32" FontWeight="Bold"
                                   Foreground="#1976D2" HorizontalAlignment="Center"/>
                        <TextBlock Text="Новые" Foreground="#6C757D" FontSize="12"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- В работе -->
                <Border Width="200" Height="110" Background="White" CornerRadius="12"
                        Margin="0,0,16,16" BoxShadow="0 2 12 0 #15000000">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="6">
                        <TextBlock Text="⚙️" FontSize="28" HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding InProgressReports}" FontSize="32" FontWeight="Bold"
                                   Foreground="#1565C0" HorizontalAlignment="Center"/>
                        <TextBlock Text="В работе" Foreground="#6C757D" FontSize="12"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- Решено -->
                <Border Width="200" Height="110" Background="White" CornerRadius="12"
                        Margin="0,0,16,16" BoxShadow="0 2 12 0 #15000000">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="6">
                        <TextBlock Text="✅" FontSize="28" HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding ResolvedReports}" FontSize="32" FontWeight="Bold"
                                   Foreground="#388E3C" HorizontalAlignment="Center"/>
                        <TextBlock Text="Решено" Foreground="#6C757D" FontSize="12"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </WrapPanel>

            <!-- Информационный блок -->
            <Border Background="White" CornerRadius="12" Padding="24"
                    BoxShadow="0 2 12 0 #15000000">
                <StackPanel Spacing="12">
                    <TextBlock Text="📌 Как подать обращение?"
                               FontSize="16" FontWeight="SemiBold" Foreground="#1A1F2E"/>
                    <StackPanel Spacing="8">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <Border Background="#E3F2FD" CornerRadius="50" Width="28" Height="28">
                                <TextBlock Text="1" HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           FontWeight="Bold" Foreground="#1976D2" FontSize="13"/>
                            </Border>
                            <TextBlock Text="Перейдите на вкладку «Создать жалобу»"
                                       VerticalAlignment="Center" Foreground="#495057"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <Border Background="#E3F2FD" CornerRadius="50" Width="28" Height="28">
                                <TextBlock Text="2" HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           FontWeight="Bold" Foreground="#1976D2" FontSize="13"/>
                            </Border>
                            <TextBlock Text="Выберите категорию нарушения"
                                       VerticalAlignment="Center" Foreground="#495057"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <Border Background="#E3F2FD" CornerRadius="50" Width="28" Height="28">
                                <TextBlock Text="3" HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           FontWeight="Bold" Foreground="#1976D2" FontSize="13"/>
                            </Border>
                            <TextBlock Text="Опишите ситуацию и при желании отметьте «Анонимно»"
                                       VerticalAlignment="Center" Foreground="#495057"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <Border Background="#E3F2FD" CornerRadius="50" Width="28" Height="28">
                                <TextBlock Text="4" HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           FontWeight="Bold" Foreground="#1976D2" FontSize="13"/>
                            </Border>
                            <TextBlock Text="Нажмите «Отправить» — мы рассмотрим в течение 3 дней"
                                       VerticalAlignment="Center" Foreground="#495057"/>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
