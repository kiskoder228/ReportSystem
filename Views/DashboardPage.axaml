<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ReportSystem.ViewModels"
             x:Class="ReportSystem.Views.DashboardPage"
             x:DataType="vm:DashboardPageViewModel">

    <ScrollViewer>
        <StackPanel Spacing="24" Margin="0,8,0,0">

            
            <StackPanel Spacing="4">
                <TextBlock FontSize="24">
                    <Run Text="Привет, "/>
                    <Run Text="{Binding GreetingName}"/>
                    <Run Text="!"/>
                </TextBlock>
                <TextBlock Text="Вот что происходит в системе прямо сейчас"
                           FontSize="14"/>
            </StackPanel>

            
            <WrapPanel Orientation="Horizontal">

                
                <Border Width="200" Height="110" Background="LightGray" BorderBrush="Black" BorderThickness="1"
                        Margin="0,0,16,16">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="6">
                        <TextBlock Text="{Binding TotalReports}" FontSize="32" FontWeight="Bold"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="Всего заявок" FontSize="12"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                
                <Border Width="200" Height="110" Background="LightGray" BorderBrush="Black" BorderThickness="1"
                        Margin="0,0,16,16">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="6">
                        <TextBlock Text="{Binding NewReports}" FontSize="32" FontWeight="Bold"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="Новые" FontSize="12"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                
                <Border Width="200" Height="110" Background="LightGray" BorderBrush="Black" BorderThickness="1"
                        Margin="0,0,16,16">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="6">
                        <TextBlock Text="{Binding InProgressReports}" FontSize="32" FontWeight="Bold"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="В работе" FontSize="12"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                
                <Border Width="200" Height="110" Background="LightGray" BorderBrush="Black" BorderThickness="1"
                        Margin="0,0,16,16">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="6">
                        <TextBlock Text="{Binding ResolvedReports}" FontSize="32" FontWeight="Bold"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="Решено" FontSize="12"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </WrapPanel>

            
            <Border Background="LightGray" BorderBrush="Black" BorderThickness="1" Padding="24">
                <StackPanel Spacing="12">
                    <TextBlock Text="Как подать обращение?"
                               FontSize="16" FontWeight="SemiBold"/>
                    <StackPanel Spacing="8">
                        <TextBlock Text="1. Перейдите на вкладку «Создать жалобу»"/>
                        <TextBlock Text="2. Выберите категорию нарушения"/>
                        <TextBlock Text="3. Опишите ситуацию и при желании отметьте «Анонимно»"/>
                        <TextBlock Text="4. Нажмите «Отправить» — мы рассмотрим в течение 3 дней"/>
                    </StackPanel>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>

